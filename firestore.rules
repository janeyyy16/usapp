rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Users collection - allow reading for username login lookup
    match /users/{userId} {
      // Allow unauthenticated read for username login lookup
      // This is safe because passwords are in Firebase Auth, not Firestore
      allow read: if true;
      
      // Users can read their own profile
      allow read: if request.auth != null && request.auth.uid == userId;
      
      // Only system/admin can write
      allow write: if false;
    }

    // Role-grouped user records: users/{ROLE}/{Active|Inactive}/{uid}
    // Navigable by role in the Firestore console.
    match /users/{role}/{status}/{uid} {
      allow read: if true; // login lookup + profile reads
      allow write: if request.auth != null;
    }

    // Flat lookup index mirroring every user by uid: users_index/{uid}
    match /users_index/{uid} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // Users can read their company
    match /companies/{companyId} {
      allow read: if request.auth != null;
      allow write: if false; // Only system/admin can write
    }
    
    // Temporarily allow authenticated users to write (for testing)
    // Remove this after setup is complete
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
